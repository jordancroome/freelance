{
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/admin",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/admin/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    },
    {
      "source": "/content/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/work/contact",
      "destination": "/contact",
      "permanent": false
    },
    {
      "source": "/work/contact/",
      "destination": "/contact",
      "permanent": false
    },
    {
      "source": "/work/services",
      "destination": "/services",
      "permanent": false
    },
    {
      "source": "/work/about",
      "destination": "/about",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/contact", "destination": "/contact/index.html" },
    { "source": "/contact/", "destination": "/contact/index.html" },
    { "source": "/services", "destination": "/services/index.html" },
    { "source": "/services/", "destination": "/services/index.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/about/", "destination": "/about/index.html" },
    { "source": "/work", "destination": "/work/index.html" },
    { "source": "/work/", "destination": "/work/index.html" },
    { "source": "/work/:slug", "destination": "/work/index.html" }
  ]
}
