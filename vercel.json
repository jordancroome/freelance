{
  "buildCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/content/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/work/:slug", "destination": "/work/index.html" }
  ]
}
